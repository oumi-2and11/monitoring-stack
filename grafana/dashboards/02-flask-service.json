{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request QPS (by status code)",
      "description": "Flask 服务每秒请求数，按 HTTP 状态码分类。200=正常响应，500=服务器错误。正常情况下 200 占主导；运行触发脚本后可观察 500 上升。",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "200" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "500" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by(status_code) (rate(flask_http_request_total{job=\"flask_app\"}[1m]))",
          "legendFormat": "{{ status_code }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate (%)",
      "description": "5xx 错误率 = 5xx 请求数 / 总请求数 x 100%。注意：仅访问 /error 时错误率为 100%（因为全部请求都是错误），需同时访问正常接口 / 才能看到混合比例。阈值 5% 触发 FlaskAppErrorRateHigh 告警。",
      "type": "gauge",
      "gridPos": { "h": 9, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "noValue": "N/A",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "(sum(rate(flask_http_request_total{job=\"flask_app\",status_code=~\"5..\"}[1m])) / sum(rate(flask_http_request_total{job=\"flask_app\"}[1m]))) * 100",
          "legendFormat": "5xx",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Requests",
      "description": "Flask 服务自启动以来的请求总计数，来自 Counter 指标累加值。",
      "type": "stat",
      "gridPos": { "h": 9, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "value" },
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "sum(flask_http_request_total{job=\"flask_app\"})",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Latency (P50 / P95 / P99)",
      "description": "请求延迟分位数。P50=中位数（50%的请求低于此值），P95=95%线（95%的请求低于此值），P99=99%线（99%的请求低于此值，反映尾部延迟）。/slow 接口会显著推高 P95/P99。",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "P50 中位数" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P95 95%线" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P99 99%线" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le) (rate(flask_http_request_duration_seconds_bucket{job=\"flask_app\"}[2m])))",
          "legendFormat": "P50 中位数",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by(le) (rate(flask_http_request_duration_seconds_bucket{job=\"flask_app\"}[2m])))",
          "legendFormat": "P95 95%线",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le) (rate(flask_http_request_duration_seconds_bucket{job=\"flask_app\"}[2m])))",
          "legendFormat": "P99 99%线",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Request Latency by Endpoint",
      "description": "各端点的 P95 延迟对比。/ = 正常快速响应，/error = 立即返回 500，/slow = 模拟 0.5-3.0 秒延迟。可定位性能瓶颈的具体端点。",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/ .*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/error .*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/slow .*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(le,endpoint) (rate(flask_http_request_duration_seconds_bucket{job=\"flask_app\"}[2m])))",
          "legendFormat": "{{ endpoint }} P95",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Alert Status",
      "description": "FlaskAppErrorRateHigh 告警当前状态。OK = 错误率低于 5% 阈值，FIRING = 错误率超过 5% 并持续 1 分钟。数据来自 Prometheus 内置 ALERTS 指标。",
      "type": "stat",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "noValue": "OK",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "OK", "color": "green" },
                "1": { "text": "FIRING", "color": "red" }
              }
            }
          ]
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "count(ALERTS{alertname=\"FlaskAppErrorRateHigh\",alertstate=\"firing\"}) > bool 0",
          "legendFormat": "FlaskAppErrorRateHigh",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["flask", "service", "business"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m"],
    "time_options": ["5m", "15m", "30m", "1h", "6h", "12h", "24h"]
  },
  "refresh": "10s",
  "title": "Flask Service Overview",
  "uid": "flask-service-overview",
  "version": 1
}