{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "CPU Usage (%)",
      "description": "主机 CPU 使用率，取 idle 模式的补数。阈值 80% 触发 HostHighCpuLoad 告警。",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 5
          },
          "thresholds": {
            "mode": "area",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Memory Usage (%)",
      "description": "主机内存使用率。MemAvailable 包含可回收缓存，比 MemFree 更准确。阈值 90% 触发 HostHighMemoryUsage 告警。",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 5
          },
          "thresholds": {
            "mode": "area",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "100 - (100 * node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Disk Usage (%)",
      "description": "各文件系统挂载点的磁盘使用率。已过滤 ext4/vfat/ntfs/overlay 等真实文件系统，排除 tmpfs 等虚拟文件系统。",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 5
          },
          "thresholds": {
            "mode": "area",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "100 - (100 * node_filesystem_avail_bytes{fstype=~\"ext4|vfat|ntfs|overlay\"} / node_filesystem_size_bytes{fstype=~\"ext4|vfat|ntfs|overlay\"})",
          "legendFormat": "{{ mountpoint }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Network I/O (bytes/sec)",
      "description": "主机网络吞吐量。RX=接收流量，TX=发送流量。按 eth 网卡过滤，排除 lo 回环接口。",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "RX.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "TX.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device=~\"eth.*\"}[2m])",
          "legendFormat": "RX {{ device }}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device=~\"eth.*\"}[2m])",
          "legendFormat": "TX {{ device }}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Container CPU Usage (cores)",
      "description": "所有容器的 CPU 总使用量，单位为核心数。值 1.0 = 占满 1 个 CPU 核心。WSL2 环境下 cAdvisor 无法获取单容器数据，此为全部容器汇总。阈值 80% 核心数触发 ContainerHighCpu 告警。",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 5
          },
          "thresholds": {
            "mode": "area",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 4 }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{id=\"/\",cpu=\"total\"}[2m])) by (instance)",
          "legendFormat": "容器 CPU (核心数)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Container Memory Usage",
      "description": "所有容器的工作集内存总使用量。working_set 为不可被驱逐的内存，比 usage_bytes 更真实反映内存压力。WSL2 环境下 cAdvisor 无法获取单容器数据，此为全部容器汇总。",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Working Set" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Usage" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{id=\"/\"}",
          "legendFormat": "Working Set",
          "refId": "A"
        },
        {
          "expr": "container_memory_usage_bytes{id=\"/\"}",
          "legendFormat": "Usage",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Service Health",
      "description": "各采集目标健康状态。1=UP（正常），0=DOWN（异常）。数据来自 Prometheus 内置 up 指标，每个 scrape job 产生一条。",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{ job }}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["host", "docker", "node_exporter", "cadvisor"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m"],
    "time_options": ["5m", "15m", "30m", "1h", "6h", "12h", "24h"]
  },
  "refresh": "10s",
  "title": "Host & Docker Overview",
  "uid": "host-docker-overview",
  "version": 1
}